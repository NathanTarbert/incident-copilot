# OpenAI API key (required for self-hosted runtime)
OPENAI_API_KEY=your_api_key_here

# CopilotKit Runtime URL (default: http://localhost:4000/copilotkit)
VITE_COPILOTKIT_RUNTIME_URL=http://localhost:4000/copilotkit

# CopilotKit Cloud API key (alternative to self-hosted runtime)
# Get your key from: https://cloud.copilotkit.ai
VITE_COPILOTKIT_PUBLIC_API_KEY=
