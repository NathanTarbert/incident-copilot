# CopilotKit Configuration
# Copy this file to .env and fill in your values

# 1 of 2 options for hosting or self-hosted runtime below

VITE_COPILOTKIT_PUBLIC_API_KEY=<using copilot cloud>
# Public API Key for CopilotKit Cloud (optional for local development)
# Get your API key from: https://cloud.copilotkit.ai

OPENAI_API_KEY=<self hosted option>

# Runtime URL for CopilotKit
# Default: http://localhost:4000/copilotkit
VITE_COPILOTKIT_RUNTIME_URL=http://localhost:4000/copilotkit

# Get your API key from: https://cloud.copilotkit.ai
VITE_COPILOTKIT_PUBLIC_API_KEY=

# Show CopilotKit Dev Console
# Set to 'true' to enable the developer console for debugging
# Default: false
VITE_COPILOTKIT_SHOW_DEV_CONSOLE=false
